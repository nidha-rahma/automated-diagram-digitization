# =========================
# Frontend (React)
# =========================
/frontend/node_modules/
/frontend/dist/
/frontend/dist-ssr/
/frontend/*.local

# Logs
/frontend/logs
/frontend/*.log
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*
/frontend/pnpm-debug.log*
/frontend/lerna-debug.log*

# =========================
# Backend (Python)
# =========================
/backend/__pycache__/
/backend/venv/
/backend/.env
/backend/*.pyc

# =========================
# Root-level artifacts
# =========================
/node_modules/
/venv/
*.log

# =========================
# Environment Files (Global)
# =========================
.env
.env.local
.env.*.local

# =========================
# Editor / OS Files
# =========================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
